# Security headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Vite build output — filenames are content-hashed, safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache headers for static assets
/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

# The only png/ico/svg served outside /assets/* are the favicons, and those
# filenames are NOT content-hashed — marking them immutable would pin an icon
# redesign out of returning visitors' caches for a year. Hashed build output
# stays immutable via /assets/* above, which matches first.
# Note: matching rules are MERGED, not overridden (a second Cache-Control is
# appended and the first directive wins), so a per-file override below cannot
# undo an immutable rule here — the rule itself has to be right.
/*.png
  Cache-Control: public, max-age=86400, must-revalidate

/*.ico
  Cache-Control: public, max-age=86400, must-revalidate

/*.svg
  Cache-Control: public, max-age=86400, must-revalidate

# HTML files should not be cached
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# JSON files (locales) and JS files - short cache
/*.json
  Cache-Control: public, max-age=3600

/*.js
  Cache-Control: public, max-age=3600

# Markdown files
/*.md
  Cache-Control: public, max-age=3600
