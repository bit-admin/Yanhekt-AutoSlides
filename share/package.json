{
  "name": "autoslides-share",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AutoSlides share viewer (v1) + AutoSlides Index (v2) — Cloudflare Worker, KV short links, D1 metadata.",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build -c vite.apex.config.ts",
    "typecheck": "tsc --noEmit",
    "preview": "wrangler dev",
    "db:migrate": "wrangler d1 migrations apply autoslides-index",
    "db:migrate:local": "wrangler d1 migrations apply autoslides-index --local",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "wrangler": "^3.99.0"
  }
}
